# Anthropic
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# Neo4j
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USERNAME=your-username
NEO4J_PASSWORD=your-password
NEO4J_DATABASE=your-database

# PostgreSQL
POSTGRES_USER=benwa
POSTGRES_PASSWORD=changeme
POSTGRES_DB=benwa_intelligence
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://benwa:changeme@postgres:5432/benwa_intelligence

# Redis
REDIS_URL=redis://redis:6379/0

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# Services
SEMANTIC_AIRLOCK_PORT=8001
BELIEF_STATE_ENGINE_PORT=8002
SOLVER_ENGINE_PORT=8003
INGESTION_GATEWAY_PORT=8004
